+              status: "confirmed",
+            },
+          },
+          {
+            new: true,
+          },
+        ).lean();
+
+      if (!confirmedReservation) {
+        const latestReservation =
+          await PreorderReservation.findOne(
+            reservationScope,
+          ).lean();
