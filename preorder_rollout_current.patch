+  if (startDate == null && dueDate == null) {
+    return true;
+  }
+  if (startDate != null &&
+      normalizedWorkDate.isBefore(_toDayStart(startDate))) {
+    return false;
+  }
+  if (dueDate != null && normalizedWorkDate.isAfter(_toDayStart(dueDate))) {
+    return false;
+  }
+  return true;
