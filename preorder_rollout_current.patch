+async function confirmPreorderReservation(
+  req,
+  res,
+) {
+  debug(
+    "BUSINESS CONTROLLER: confirmPreorderReservation - entry",
+    {
+      actorId: req.user?.sub,
+      reservationId:
+        req.params?.id || "",
+      intent:
+        "mark reserved preorder hold as confirmed after successful payment",
+    },
