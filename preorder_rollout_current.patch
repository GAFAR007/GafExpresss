+String _toWorkDateKey(DateTime? date) {
+  if (date == null) {
+    return "";
+  }
+  final year = date.year.toString().padLeft(4, "0");
+  final month = date.month.toString().padLeft(2, "0");
+  final day = date.day.toString().padLeft(2, "0");
+  return "$year-$month-$day";
