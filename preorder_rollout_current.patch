+
+async function requestJson({
+  routePath,
+}) {
+  return new Promise((resolve, reject) => {
+    const request = http.request(
+      {
+        method: "GET",
+        hostname: "127.0.0.1",
+        port: server.address().port,
+        path: routePath,
+      },
+      (response) => {
+        let raw = "";
+        response.on("data", (chunk) => {
+          raw += chunk.toString();
+        });
+        response.on("end", () => {
+          const parsed =
+            raw.trim().length > 0 ?
+              JSON.parse(raw)
+            : {};
+          resolve({
+            statusCode:
+              response.statusCode || 0,
+            body: parsed,
+          });
+        });
+      },
+    );
+
+    request.on("error", reject);
+    request.end();
+  });
+}
+
