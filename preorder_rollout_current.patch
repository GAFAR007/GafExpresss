+  businessId,
+  role,
+  email,
+}) {
+  return User.create({
+    _id: id,
+    name: `${role}-${id.toString().slice(-6)}`,
+    email,
+    passwordHash: "hashed_for_tests",
+    role,
+    businessId,
+  });
+}
+
+async function createAsset({
