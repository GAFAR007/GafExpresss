+        } else if (!latestReservation) {
+          return res.status(404).json({
+            error:
+              PRODUCTION_COPY.PREORDER_RESERVATION_NOT_FOUND,
+          });
+        } else {
+          return res.status(409).json({
+            error:
+              PRODUCTION_COPY.PREORDER_CONFIRM_STATUS_INVALID,
+          });
+        }
+      }
+    }
+
+    const plan =
