+async function requestJson({
+  routePath,
+  token,
+}) {
+  return new Promise((resolve, reject) => {
+    const body = "{}";
+    const request = http.request(
+      {
+        method: "POST",
+        hostname: "127.0.0.1",
+        port: server.address().port,
+        path: routePath,
+        headers: {
+          "Content-Type":
+            "application/json",
+          "Content-Length":
+            Buffer.byteLength(body),
+          Authorization: `Bearer ${token}`,
+        },
+      },
+      (response) => {
+        let raw = "";
+        response.on("data", (chunk) => {
+          raw += chunk.toString();
+        });
+        response.on("end", () => {
+          const parsed =
+            raw.trim().length > 0 ?
+              JSON.parse(raw)
+            : {};
+          resolve({
+            statusCode:
+              response.statusCode || 0,
+            body: parsed,
+          });
+        });
+      },
+    );
+
+    request.on("error", reject);
+    request.write(body);
+    request.end();
+  });
+}
