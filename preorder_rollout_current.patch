+bool _isTaskScheduledForDate({
+  required ProductionTask task,
+  required DateTime workDate,
+}) {
+  final normalizedWorkDate = _toDayStart(workDate);
+  final startDate = task.startDate;
+  final dueDate = task.dueDate;
