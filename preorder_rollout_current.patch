+    );
+  if (!orderScopedToBusiness) {
+    throw new Error(
+      "Linked pre-order reservation business scope mismatch",
+    );
+  }
+
+  if (
+    reservation.status ===
+    PREORDER_STATUS_CONFIRMED
+  ) {
+    return {
+      applied: false,
+      idempotent: true,
+      skipped: false,
+      status: reservation.status,
+    };
+  }
+  if (
