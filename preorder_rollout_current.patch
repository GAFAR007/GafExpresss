+          PRODUCTION_COPY.PREORDER_RESERVATION_NOT_FOUND,
+      });
+    }
+
+    let idempotent = false;
+    let confirmedReservation = null;
+
+    if (
+      existingReservation.status ===
+      "confirmed"
+    ) {
+      idempotent = true;
+      confirmedReservation =
+        existingReservation;
+    } else {
+      if (
+        existingReservation.status !==
+        "reserved"
