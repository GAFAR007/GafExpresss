+      _id: reservationId,
+      businessId,
+    };
+    // WHY: Customers can only release their own reservation records.
+    if (actor.role === "customer") {
+      reservationScope.userId = actor._id;
+    }
+
+    const existingReservation =
+      await PreorderReservation.findOne(
+        reservationScope,
+      ).lean();
