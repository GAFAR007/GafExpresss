+            createdBy: actor._id,
+          },
+        },
+        {
+          new: true,
+          upsert: true,
+          setDefaultsOnInsert: true,
+        },
+      ).lean();
+
+    debug(
+      "BUSINESS CONTROLLER: logProductionTaskProgress - success",
+      {
+        actorId: actor._id,
+        taskId: task._id,
+        planId: plan._id,
