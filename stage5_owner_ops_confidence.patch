+  debug(
+    "BUSINESS CONTROLLER: releasePreorderReservation - entry",
+    {
+      actorId: req.user?.sub,
+      reservationId:
+        req.params?.id || "",
+      intent:
+        "release reserved preorder hold back into available capacity",
+    },
