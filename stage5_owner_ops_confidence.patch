+    Number(product?.preorderCapQuantity || 0),
+  );
+  const reserved = Math.max(
+    0,
+    Number(product?.preorderReservedQuantity || 0),
+  );
+  const remaining = Math.max(
+    0,
+    cap - reserved,
+  );
+
+  return {
+    cap,
+    reserved,
